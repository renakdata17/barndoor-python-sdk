# Barndoor SDK – Environment template
#
# Auth URLs are baked into the SDK per environment - you don't need to configure them!

# Required for login
AGENT_CLIENT_ID=<your-client-id>
AGENT_CLIENT_SECRET=<your-client-secret>

# Environment (optional - defaults to production)
# Prefer BARNDOOR_ENV; MODE remains as a legacy alias when BARNDOOR_ENV is unset.
#
# Trial environments (default):
#   production (or prod) - https://auth.barndoor.ai
#   uat                  - https://auth.barndooruat.com
#   dev (or development) - https://auth.barndoordev.com
#
# Enterprise environments (requires prefix):
#   enterprise-production (or enterprise-prod, enterprise)
#   enterprise-uat
#   enterprise-dev
#
# Local development:
#   localdev (or local) - http://localhost:8080
#
BARNDOOR_ENV=production

# Optional overrides (uncomment only if needed for custom setups)
# AUTH_URL=https://custom.auth.server/realms/my-realm
# BARNDOOR_URL=https://{org_slug}.platform.barndoor.ai
